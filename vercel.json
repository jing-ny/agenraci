{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "outputDirectory": ".",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/docs/playground/"
    }
  ],
  "git": {
    "deploymentEnabled": {
      "*": false,
      "**": false,
      "main": true
    }
  }
}
